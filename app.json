{
  "expo": {
    "name": "MoacirFilms",
    "slug": "moacirfilms",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000010"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.moacir.moacirfilms",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000010"
      }
    },
    "web": {
      "bundler": "metro",
      "backgroundColor": "#0a0a0f",
      "favicon": "./assets/favicon.png"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "ae1a5b87-0da6-4da5-93de-76df59af5fa7"
      }
    }
  }
}
